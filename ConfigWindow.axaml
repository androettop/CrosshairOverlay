<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="CrosshairOverlay.ConfigWindow"
        Width="720"
        Height="760"
        MinWidth="560"
        MinHeight="620"
        Title="Crosshair Overlay Settings">
    <ScrollViewer Margin="12">
        <StackPanel Spacing="14">
            <TextBlock x:Name="HeaderTitle" Text="Overlay Settings" FontSize="24" FontWeight="Bold" />

            <Border BorderBrush="#445" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="GeneralTitle" Text="General" FontSize="18" FontWeight="SemiBold" />

                    <TextBlock x:Name="LanguageLabel" Text="Language" />
                    <ComboBox x:Name="Language" SelectionChanged="OnAnySettingChanged">
                        <ComboBoxItem x:Name="LanguageSpanishItem" Content="Español" Tag="es" />
                        <ComboBoxItem x:Name="LanguageEnglishItem" Content="English" Tag="en" />
                    </ComboBox>

                    <TextBlock x:Name="MonitorsLabel" Text="Monitors" />
                    <StackPanel x:Name="MonitorSelectorPanel" Spacing="6" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#445" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CenterDotTitle" Text="Center Dot" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox x:Name="EnableCenterDot" Content="Enable center dot" IsCheckedChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CenterDotShapeLabel" Text="Shape" />
                    <ComboBox x:Name="CenterDotShape" SelectedIndex="0" SelectionChanged="OnAnySettingChanged">
                        <ComboBoxItem x:Name="CenterDotShapeCircleItem" Content="Circle" />
                        <ComboBoxItem x:Name="CenterDotShapeSquareItem" Content="Square" />
                    </ComboBox>

                    <TextBlock x:Name="CenterDotSizeLabel" Text="Size: 6" />
                    <Slider x:Name="CenterDotSize" Minimum="1" Maximum="800" Value="6" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CenterDotOpacityLabel" Text="Opacity: 1.00" />
                    <Slider x:Name="CenterDotOpacity" Minimum="0" Maximum="1" Value="1" TickFrequency="0.01" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CenterDotColorLabel" Text="Color (#RRGGBB or #AARRGGBB)" />
                    <TextBox x:Name="CenterDotColor" Text="#FFFFFF" PlaceholderText="#FFFFFF" TextChanged="OnAnySettingChanged" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#445" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="DotGridTitle" Text="Dot Grid" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox x:Name="EnableDotGrid" Content="Enable dot grid" IsCheckedChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="DotGridPointShapeLabel" Text="Point shape" />
                    <ComboBox x:Name="DotGridPointShape" SelectedIndex="0" SelectionChanged="OnAnySettingChanged">
                        <ComboBoxItem x:Name="DotGridPointShapeCircleItem" Content="Circle" />
                        <ComboBoxItem x:Name="DotGridPointShapeSquareItem" Content="Square" />
                    </ComboBox>

                    <TextBlock x:Name="DotGridAreaShapeLabel" Text="Grid area shape" />
                    <ComboBox x:Name="DotGridAreaShape" SelectedIndex="0" SelectionChanged="OnDotGridAreaShapeChanged">
                        <ComboBoxItem x:Name="DotGridAreaSquareItem" Content="Square" />
                        <ComboBoxItem x:Name="DotGridAreaCircleItem" Content="Circle" />
                    </ComboBox>

                    <TextBlock x:Name="DotGridPointSizeLabel" Text="Point size: 3" />
                    <Slider x:Name="DotGridPointSize" Minimum="1" Maximum="200" Value="3" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="DotGridSpacingLabel" Text="Point spacing: 10" />
                    <Slider x:Name="DotGridSpacing" Minimum="1" Maximum="250" Value="10" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <StackPanel x:Name="DotGridSquarePanel" Spacing="8">
                        <TextBlock x:Name="DotGridRowsLabel" Text="Rows: 7" />
                        <Slider x:Name="DotGridRows" Minimum="1" Maximum="120" Value="7" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                        <TextBlock x:Name="DotGridColumnsLabel" Text="Columns: 7" />
                        <Slider x:Name="DotGridColumns" Minimum="1" Maximum="120" Value="7" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />
                    </StackPanel>

                    <StackPanel x:Name="DotGridCirclePanel" Spacing="8">
                        <TextBlock x:Name="DotGridRadiusPointsLabel" Text="Radius points: 4" />
                        <Slider x:Name="DotGridRadiusPoints" Minimum="1" Maximum="80" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />
                    </StackPanel>

                    <TextBlock x:Name="DotGridOpacityLabel" Text="Opacity: 0.80" />
                    <Slider x:Name="DotGridOpacity" Minimum="0" Maximum="1" Value="0.8" TickFrequency="0.01" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="DotGridColorLabel" Text="Color (#RRGGBB or #AARRGGBB)" />
                    <TextBox x:Name="DotGridColor" Text="#00FF00" PlaceholderText="#00FF00" TextChanged="OnAnySettingChanged" />
                </StackPanel>
            </Border>

            <Border BorderBrush="#445" BorderThickness="1" CornerRadius="8" Padding="12">
                <StackPanel Spacing="10">
                    <TextBlock x:Name="CrosshairTitle" Text="Crosshair" FontSize="18" FontWeight="SemiBold" />
                    <CheckBox x:Name="EnableCrosshair" Content="Enable crosshair" IsCheckedChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairHorizontalLengthLabel" Text="Horizontal length: 16" />
                    <Slider x:Name="CrosshairHorizontalLength" Minimum="0" Maximum="2000" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairVerticalLengthLabel" Text="Vertical length: 16" />
                    <Slider x:Name="CrosshairVerticalLength" Minimum="0" Maximum="2000" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairGapLabel" Text="Gap: 4" />
                    <Slider x:Name="CrosshairGap" Minimum="0" Maximum="800" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairThicknessLabel" Text="Thickness: 2" />
                    <Slider x:Name="CrosshairThickness" Minimum="1" Maximum="800" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairOpacityLabel" Text="Opacity: 0.90" />
                    <Slider x:Name="CrosshairOpacity" Minimum="0" Maximum="1" Value="0.9" TickFrequency="0.01" ValueChanged="OnAnySettingChanged" />

                    <TextBlock x:Name="CrosshairColorLabel" Text="Color (#RRGGBB or #AARRGGBB)" />
                    <TextBox x:Name="CrosshairColor" Text="#FF0000" PlaceholderText="#FF0000" TextChanged="OnAnySettingChanged" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
